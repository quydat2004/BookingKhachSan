@{
    ViewData["Title"] = "Quản lý booking";
    ViewData["Subtitle"] = "Theo dõi đặt phòng, xác nhận, check-in, check-out và hủy booking";
}

<section class="stat-grid">
    <article class="stat-card"><span>Pending</span><strong>12</strong><small>Cần xác nhận</small></article>
    <article class="stat-card"><span>Confirmed</span><strong>24</strong><small>Sắp nhận phòng</small></article>
    <article class="stat-card"><span>Checked-in</span><strong>8</strong><small>Đang lưu trú</small></article>
    <article class="stat-card"><span>Checked-out</span><strong>41</strong><small>Hoàn tất tháng này</small></article>
</section>

<section class="admin-card">
    <div class="admin-card-header">
        <div>
            <h2>Bộ lọc booking</h2>
            <p>HTML preview, chưa xử lý submit.</p>
        </div>
        <button class="btn-preview primary">Xuất báo cáo</button>
    </div>
    <div class="filter-bar">
        <div class="form-preview">Mã booking, tên khách...</div>
        <div class="form-preview">Trạng thái: Tất cả</div>
        <div class="form-preview">Khách sạn</div>
        <div class="form-preview">Ngày nhận phòng</div>
        <button class="btn-preview primary">Lọc</button>
    </div>
</section>

<section class="admin-card">
