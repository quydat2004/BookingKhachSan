@{
    ViewData["Title"] = "Chi tiết khách sạn";
}

<section class="page-hero">
    <div class="container">
        <span class="badge-soft badge-completed">Đang hoạt động</span>
        <h1 class="mt-3">Prestige Sài Gòn</h1>
        <p class="text-muted">Quận 1, TP. Hồ Chí Minh · ★★★★★ · 4.8/5 từ 128 đánh giá</p>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="row g-3 mb-4">
                    <div class="col-md-8"><div class="gallery-main rounded-4" style="height:320px">Ảnh chính khách sạn</div></div>
                    <div class="col-md-4 d-grid gap-3"><div class="gallery-item rounded-4">Lobby</div><div class="gallery-item rounded-4">Phòng</div></div>
                </div>

                <div class="content-card p-4 mb-4">
                    <h2 class="section-title h3">Giới thiệu</h2>
                    <p class="text-muted mb-0">Khách sạn 5 sao tại trung tâm thành phố, phù hợp nghỉ dưỡng, công tác và du lịch gia đình. Giao diện này là HTML tĩnh để xem flow trước khi ráp dữ liệu thật.</p>
                </div>

                <div class="content-card p-4 mb-4">
                    <h2 class="section-title h3">Tiện nghi nổi bật</h2>
                    <div class="row g-3 mt-1">
                        <div class="col-md-4"><div class="metric-box">Wifi miễn phí <strong>24/7</strong></div></div>
                        <div class="col-md-4"><div class="metric-box">Hồ bơi <strong>Tầng 20</strong></div></div>
                        <div class="col-md-4"><div class="metric-box">Bữa sáng <strong>Buffet</strong></div></div>
                        <div class="col-md-4"><div class="metric-box">Spa <strong>Premium</strong></div></div>
                        <div class="col-md-4"><div class="metric-box">Đưa đón <strong>Sân bay</strong></div></div>
                        <div class="col-md-4"><div class="metric-box">Gym <strong>Miễn phí</strong></div></div>
                    </div>
                </div>

                <div class="content-card p-4 mb-4">
                    <h2 class="section-title h3">Loại phòng</h2>
                    <div class="room-row"><div><h4 class="fw-bold">Deluxe King</h4><p class="text-muted mb-0">2 khách · 1 giường king · còn 4 phòng</p></div><div class="text-lg-end"><div class="price">1.200.000₫</div><a class="btn btn-outline-primary rounded-pill" asp-controller="Bookings" asp-action="Create">Chọn phòng</a></div></div>
                    <div class="room-row"><div><h4 class="fw-bold">Premium Twin</h4><p class="text-muted mb-0">2 khách · 2 giường đơn · còn 2 phòng</p></div><div class="text-lg-end"><div class="price">1.450.000₫</div><a class="btn btn-outline-primary rounded-pill" asp-controller="Bookings" asp-action="Create">Chọn phòng</a></div></div>
                    <div class="room-row"><div><h4 class="fw-bold">Family Suite</h4><p class="text-muted mb-0">4 khách · 2 phòng ngủ · còn 1 phòng</p></div><div class="text-lg-end"><div class="price">2.400.000₫</div><a class="btn btn-outline-primary rounded-pill" asp-controller="Bookings" asp-action="Create">Chọn phòng</a></div></div>
                </div>

                <div class="content-card p-4">
                    <h2 class="section-title h3">Đánh giá khách hàng</h2>
                    <div class="review-card p-3 mt-3"><div class="review-stars">★★★★★</div><p class="mb-1 fw-bold">Dịch vụ tốt, phòng sạch</p><p class="text-muted mb-0">Nhân viên thân thiện, vị trí thuận tiện. Sẽ quay lại.</p></div>
                    <div class="review-card p-3 mt-3"><div class="review-stars">★★★★☆</div><p class="mb-1 fw-bold">Đáng tiền</p><p class="text-muted mb-0">Bữa sáng ngon, check-in hơi đông giờ cao điểm.</p></div>
                </div>
            </div>

            <div class="col-lg-4">
                <aside class="content-card summary-card">
                    <h3 class="fw-bold">Đặt phòng nhanh</h3>
                    <div class="form-preview my-3">Nhận phòng: 10/06/2026</div>
                    <div class="form-preview mb-3">Trả phòng: 12/06/2026</div>
                    <div class="form-preview mb-3">2 khách · Deluxe King</div>
                    <div class="summary-line"><span>2 đêm</span><strong>2.400.000₫</strong></div>
                    <div class="summary-line"><span>Thuế phí</span><strong>240.000₫</strong></div>
                    <div class="summary-line"><span>Tổng</span><strong class="summary-total">2.640.000₫</strong></div>
                    <a class="btn btn-primary btn-lg w-100 rounded-pill mt-3" asp-controller="Bookings" asp-action="Create">Đặt phòng ngay</a>
                </aside>
            </div>
        </div>
    </div>
</section>
