<section class="section"><div class="container"><div class="row g-4"><div class="col-lg-8"><div class="payment-card p-4"><h3 class="fw-bold mb-3">Phương thức thanh toán</h3><div class="payment-option"><div><strong>VNPay</strong><p class="text-muted mb-0">Thanh toán qua thẻ ATM, Visa, QR.</p></div><span class="badge-soft badge-confirmed">Khuyên dùng</span></div><div class="payment-option"><div><strong>MoMo</strong><p class="text-muted mb-0">Thanh toán ví điện tử MoMo.</p></div><button class="btn btn-outline-primary rounded-pill">Chọn</button></div><div class="payment-option"><div><strong>Tiền mặt</strong><p class="text-muted mb-0">Thanh toán tại quầy khi nhận phòng.</p></div><button class="btn btn-outline-primary rounded-pill">Chọn</button></div></div></div><div class="col-lg-4"><aside class="content-card summary-card"><h3 class="fw-bold">BK-2026-0018</h3><p class="text-muted">Prestige Sài Gòn · Deluxe King</p><div class="summary-line"><span>Tiền phòng</span><strong>2.400.000₫</strong></div><div class="summary-line"><span>Voucher</span><strong class="text-success">-120.000₫</strong></div><div class="summary-line"><span>Thuế phí</span><strong>228.000₫</strong></div><div class="summary-line"><span>Tổng</span><strong class="summary-total">2.508.000₫</strong></div><a class="btn btn-primary btn-lg w-100 rounded-pill mt-3" asp-controller="Payments" asp-action="Success">Thanh toán ngay</a><a class="btn btn-outline-danger w-100 rounded-pill mt-2" asp-controller="Payments" asp-action="Failed">Mô phỏng lỗi</a></aside></div></div></div></section>
